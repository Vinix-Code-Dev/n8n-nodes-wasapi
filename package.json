{
  "name": "@wasapi/n8n-nodes-wasapi",
  "version": "4.0.1",
  "description": "Nodo n8n para integración con Wasapi API",
  "type": "commonjs",
  "keywords": [
    "n8n-community-node-package",
    "wasapi",
    "n8n",
    "meta",
    "whatsapp",
    "business",
    "api"
  ],
  "license": "MIT",
  "homepage": "https://www.wasapi.io/",
  "bugs": {
    "url": "https://github.com/Vinix-Code-Dev/n8n-nodes-wasapi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "Juan Camilo Alvarez",
    "email": "camilo@wasapi.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vinix-Code-Dev/n8n-nodes-wasapi"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lintfix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "format": "prettier nodes credentials --write"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 2,
    "credentials": [
      "dist/credentials/WasapiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Wasapi/Wasapi.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.35.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.29.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "gulp": "^5.0.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
